{
  "id": 82,
  "layerKey": "parcels",
  "layerName": "Parcels Layer",
  "enabled": true,
  "provider": {
    "type": "SqlServer",
    "connectionStringName": "Default",
    "tableName": "[UALSDb].[ualsdataview].[LayerData_82]",
    "idColumn": "Id",
    "geometryColumn": "Geom",
    "sourceSrid": 4326,
    "commandTimeoutSeconds": 120
  },
  "tile": {
    "minZoom": 12,
    "maxZoom": 21,
    "maxGenerationZoom": 17,
    "extent": 4096,
    "buffer": 64,
    "clipGeometry": true,
    "returnEmptyTileOutsideZoomRange": true,
    "allowOnDemandGeneration": true
  },
  "extent": {
    "minX": 38.93,
    "minY": 21.40,
    "maxX": 39.56,
    "maxY": 22.36,
    "srid": 4326
  },
  "attributes": {
    "include": [
      "Type_t",
      "LayerId",
      "DISTRICT",
      "SUBMUNICIPALITY",
        "SUBDISTRICT_NAME",

      "PARCELNUMBER",
      "SERVICE_NAME",
      "PARCEL_LANDUSE",
      "LAND_USES",
      "PLAN_NUMBER",
      "BlockNumber"
    ]
  },
  "cacheRules": [
    { "variantKey": "default", "isDefault": true },
    {
      "variantKey": "residential",
      "displayName": "Residential land uses only",
      "filter": { "column": "Type_t", "operator": "In", "values": [ "Villa", "Admin.Tourist Housing" ] }
    }
  ],
  "cache": {
    "enabled": true,
    "refreshPeriodMinutes": 1440
  }
}
